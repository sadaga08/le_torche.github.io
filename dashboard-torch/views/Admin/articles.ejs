<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title><%= article.titre %></title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gradient-to-r from-gray-900 to-gray-800 min-h-screen">

<%- include('../Layout/header', { title: 'Dashboard', currentPage: 'dashboard' }) %>


    <div class="max-w-3xl mx-auto mt-8 px-4">
        <div class="bg-black/50 rounded-xl shadow p-8">

            <h2 class="text-2xl font-bold text-white mb-2"><%= article.titre %></h2>
            <p class="text-sm text-white/70 mb-6">
                <%= article.category %> &nbsp;|&nbsp;
                <%= new Date(article.date_publication).toLocaleDateString('fr-FR') %>
            </p>

            <% if (article.image) { %>
                <img src="/uploads/images/<%= article.image %>"
                     class="w-full max-h-80 object-cover rounded-xl mb-6" alt="image">
            <% } %>

            <% if (article.video) { %>
                <video controls class="w-full rounded-xl mb-6">
                    <source src="/uploads/videos/<%= article.video %>">
                </video>
            <% } %>

            <p class="text-white/70 leading-relaxed whitespace-pre-line"><%= article.content %></p>

            <div class="mt-8 pt-6 border-t flex justify-end">
                <form action="/dashboard/article/<%= article.id %>/delete" method="POST"
                      onsubmit="return confirm('Supprimer cet article ?')">
                    <button class="bg-red-600 text-white px-5 py-2 rounded-lg hover:bg-red-700">
                        Supprimer l'article
                    </button>
                </form>
            </div>

        </div>
    </div>

</body>
</html>